# ============================================
# TrueLens AI — Environment Configuration
# ============================================
# Copy this file to .env.dev and fill in your values.
# NEVER commit .env.dev or .env.prod to version control.

# ----- LLM Provider API Keys -----
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ----- Active Provider -----
# Options: gemini | openai | claude
ACTIVE_PROVIDER=gemini

# ----- Active Model -----
# The specific model identifier used by the active provider.
# Gemini:  gemini-2.5-flash
# OpenAI:  gpt-4o
# Claude:  claude-sonnet-4-20250514
ACTIVE_MODEL=gemini-2.5-flash

# ----- API Configuration -----
API_BASE_URL=https://api.truelens.ai/v1
REQUEST_TIMEOUT_SECONDS=60
MAX_UPLOAD_SIZE_MB=50

# ----- Feature Flags -----
ENABLE_VIDEO_ANALYSIS=true
ENABLE_PDF_EXPORT=false
ENABLE_CLOUD_SYNC=false
ENABLE_DEVELOPER_MODE=false

# ----- Debug -----
ENABLE_DEBUG_LOGGING=true
